DATABASE_URL="postgresql://postgres:postgres@localhost:5432/next_ai_board?schema=public"
SESSION_SECRET="change-this-session-secret"

# local: no external API call
# openai: use OpenAI Embeddings API
# auto: use OpenAI when OPENAI_API_KEY exists, otherwise local
EMBEDDING_PROVIDER="auto"
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# MCP weather tool
# Get a key from OpenWeather and keep the real value only in .env
OPENWEATHER_API_KEY=""
OPENWEATHER_DEFAULT_LOCATION="Seoul,KR"
OPENWEATHER_UNITS="metric"
OPENWEATHER_LANG="kr"
